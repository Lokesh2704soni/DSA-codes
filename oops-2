#include<iostream>
using namespace std;

class Human{
    protected:
    string name;
    
};

class Person
{
    protected:
    int age;
};


class student : public Human, public Person{   // function is used for access private data class
    int roll_no;
    public:
    student(string n, int a, int r){
        name = n;
        age = a;
        roll_no = r;
    }
    
    void display(){
        cout<<name<<" "<<age<<" "<<roll_no;
    }
}; 

int main(){
     student obj("Lokesh",20, 02);
     
    obj.display(); 
    
    return 0;
}
