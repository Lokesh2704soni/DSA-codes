#include<iostream>
using namespace std;
//Inheritance

class Human{
    protected:// its means iska access child class ke paass hi hoga 
    string name;
    
    
};

class person : public Human   //paremt is always on right side and child is always on left side
{
    int age;
    
    public: 
    person(string n, int a){
        name = n;
        age = a;
        
    }
    
    void display(){
        cout<<name<<" "<<age;
    }
};


int main(){   //agr inherit krna h to obj hmesha child class ka hi bnega
    
    person obj("Lokesh",20);
    obj.display(); //sbse niche vala child sbki propertie access krta hai
    
    return 0;
}
