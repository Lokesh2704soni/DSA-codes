#include <iostream>
using namespace std;
// incapsulation & abstruction

class student
{
    string name;
    int age;
    
    public:
    //setter function for the private data memners
    void setter(string n, int a){
        name = n;
        age = a;
    }
    
    //getter function return the private data members value
    int getter(){
        return age;
    }
    
    
    void display()
    {
        cout<<name<<" "<<age<<endl;
    }
    ~student(){
        cout<<"destructor is called";
    }
    
    
};

int main(){
    student obj1;
    obj1.setter("Lokesh", 20);
    cout<<obj1.getter();
    return 0;
}
