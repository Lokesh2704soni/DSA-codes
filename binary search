#include <iostream>
#include <vector>
using namespace std;

class Solution {
  
    int lowerBound(vector<int>& nums, int target) {
        int s = 0;
        int e = nums.size() - 1;
        int ans = -1;

        while (s <= e) {
            int mid = (s + e) / 2;

            if (nums[mid] == target) {
                ans = mid;
                e = mid - 1; 
            }
            else if (nums[mid] > target) {
                e = mid - 1;
            }
            else {
                s = mid + 1;
            }
        }

        return ans;
    }


    int upperBound(vector<int>& nums, int target) {
        int s = 0;
        int e = nums.size() - 1;
        int ans = -1;

        while (s <= e) {
            int mid = (s + e) / 2;

            if (nums[mid] == target) {
                ans = mid;
                s = mid + 1; 
            }
            else if (nums[mid] > target) {
                e = mid - 1;
            }
            else {
                s = mid + 1;
            }
        }

        return ans;
    }

public:
    vector<int> searchRange(vector<int>& nums, int target) {

        vector<int> arr;

        int first = lowerBound(nums, target);
        int last = upperBound(nums, target);

        arr.push_back(first);
        arr.push_back(last);

        return arr;
    }
};

int main() {

    vector<int> nums = {5, 7, 7, 8, 8, 10};
    int target = 8;

    Solution obj;

    vector<int> ans = obj.searchRange(nums, target);

    cout << ans[0] << " " << ans[1];

    return 0;
}

